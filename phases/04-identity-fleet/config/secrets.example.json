{
  "_comment": "TEMPLATE - Copiar a secrets.json y llenar con valores reales",
  "_warning": "NUNCA commitear secrets.json a Git - agregar a .gitignore",

  "ollamacloud": {
    "apiKey": "${OLLAMA_API_KEY}",
    "baseUrl": "https://api.ollamacloud.ai/v1"
  },

  "telegram": {
    "botToken": "${TELEGRAM_BOT_TOKEN}",
    "enabled": true
  },

  "discord": {
    "botToken": "${DISCORD_BOT_TOKEN}",
    "enabled": false
  },

  "email": {
    "provider": "resend",
    "apiKey": "${RESEND_API_KEY}",
    "fromAddress": "noreply@example.com"
  },

  "voice": {
    "provider": "deepgram",
    "apiKey": "${DEEPGRAM_API_KEY}",
    "_note": "v2.0: Deepgram reemplaza a Bland para STT/TTS"
  },

  "image": {
    "provider": "stable_diffusion",
    "apiKey": "${SD_API_KEY}",
    "_note": "v2.0: Stable Diffusion para generación de imágenes"
  },

  "gateway": {
    "authToken": "${GATEWAY_AUTH_TOKEN}",
    "port": 18789
  },

  "optional": {
    "openai": {
      "apiKey": "${OPENAI_API_KEY}",
      "enabled": false
    },
    "google": {
      "apiKey": "${GOOGLE_API_KEY}",
      "cseId": "${GOOGLE_CSE_ID}",
      "enabled": false
    }
  }
}