# TURNKEY v6 - Variables de Entorno Requeridas
# Copiar este archivo a .env y llenar con tus valores reales
# NUNCA commitear .env a Git

# ============================================
# OLLAMA CLOUD (Requerido)
# ============================================
OLLAMA_API_KEY=os_your_ollama_api_key_here

# ============================================
# TELEGRAM BOT (Opcional - FASE 5)
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# DISCORD BOT (Opcional - FASE 5)
# ============================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ============================================
# EMAIL - RESEND (Opcional)
# ============================================
RESEND_API_KEY=re_your_resend_api_key_here

# ============================================
# VOICE - BLAND AI (Opcional)
# ============================================
BLAND_API_KEY=your_bland_api_key_here

# ============================================
# GATEWAY (Configurado en FASE 3)
# ============================================
GATEWAY_AUTH_TOKEN=your_gateway_token_here
GATEWAY_PORT=18789

# ============================================
# PDF PROCESSING (Opcional)
# ============================================
PDFCO_API_KEY=your_pdfco_api_key_here

# ============================================
# OPENAI (Alternativo a Ollama)
# ============================================
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================
# DEEP LEARNING (Opcional)
# ============================================
DEEPL_API_KEY=your_deepl_api_key_here

# ============================================
# GOOGLE CLOUD (Opcional)
# ============================================
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id