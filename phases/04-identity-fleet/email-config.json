  "integrations": {
    "crm": {
      "enabled": true,
      "provider": "internal",
      "sync_contacts": true,
      "log_interactions": true
    },
    "slack": {
      "enabled": true,
      "notify_on_vip": true,
      "notify_on_escalation": true,
      "channel_mappings": {
        "support": "#email-support",
        "sales": "#email-sales",
        "vip": "#email-vip"
      }
    },
    "analytics": {
      "enabled": true,
      "track_metrics": [
        "sent_count",
        "received_count",
        "open_rate",
        "click_rate",
        "response_time_avg",
        "resolution_rate"
      ],
      "retention_days": 90
    }
  },
  
  "webhooks": {
    "enabled": true,
    "endpoints": [
      {
        "event": "email.received",
        "url": "https://bee.ai/api/webhooks/email/received",
        "method": "POST"
      },
      {
        "event": "email.sent",
        "url": "https://bee.ai/api/webhooks/email/sent",
        "method": "POST"
      },
      {
        "event": "email.bounced",
        "url": "https://bee.ai/api/webhooks/email/bounced",
        "method": "POST"
      },
      {
        "event": "email.opened",
        "url": "https://bee.ai/api/webhooks/email/opened",
        "method": "POST"
      }
    ]
  },
  
  "logging": {
    "level": "info",
    "sanitize": {
      "redact_pii": true,
      "fields": ["password", "token", "api_key", "authorization"]
    },
    "retention": {
      "days": 30,
      "compress_after_days": 7
    }
  },
  
  "health_check": {
    "enabled": true,
    "imap_ping_interval_ms": 300000,
    "smtp_test_interval_ms": 600000,
    "alert_on_failure": true,
    "max_consecutive_failures": 3
  }
}