# TURNKEY v6 - FASE 5: Secrets Template
# Copiar a ~/.openclaw/secrets/ con valores reales
# ⚠️ NUNCA commitear este archivo con valores reales

# ============================================
# TELEGRAM (Requerido para bot)
# ============================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_USERNAME=@tu_agente_bot
TELEGRAM_ALLOWED_USERS=123456789,987654321
TELEGRAM_ADMIN_USERS=123456789

# ============================================
# EMAIL SMTP/IMAP (Requerido para email)
# ============================================
# Opción A: SMTP propio
SMTP_HOST=mail.tu-dominio.com
SMTP_PORT=587
SMTP_USER=agente@tu-dominio.com
SMTP_PASSWORD=SECRET_PLACEHOLDER

IMAP_HOST=mail.tu-dominio.com
IMAP_PORT=993
IMAP_USER=agente@tu-dominio.com
IMAP_PASSWORD=SECRET_PLACEHOLDER

# Opción B: Resend (alternativo)
RESEND_API_KEY=re_SECRET_PLACEHOLDER

# ============================================
# DISCORD (Opcional)
# ============================================
DISCORD_BOT_TOKEN=MTQzNjcwNjUyMjU0NDIxNDAzNg...
DISCORD_GUILD_ID=1476646963494653987
DISCORD_ALLOWED_USERS=1473760780947034295

# ============================================
# WHATSAPP (Heredado de LOCAL)
# ============================================
WHATSAPP_ENABLED=true
WHATSAPP_ALLOW_FROM=+50764301378

# ============================================
# CLOUDFLARE TUNNEL (Opcional)
# ============================================
CLOUDFLARE_EMAIL=tu-email@ejemplo.com
CLOUDFLARE_API_KEY=SECRET_PLACEHOLDER
CLOUDFLARE_ACCOUNT_ID=SECRET_PLACEHOLDER
CLOUDFLARE_TUNNEL_TOKEN=SECRET_PLACEHOLDER

# ============================================
# APIs COMPARTIDAS (Opcionales)
# ============================================
# OpenAI (Opcional - ya incluido en Ollama Cloud)
OPENAI_API_KEY=sk-SECRET_PLACEHOLDER

# Anthropic (Opcional)
ANTHROPIC_API_KEY=sk-ant-SECRET_PLACEHOLDER

# Google Gemini (Opcional)
GOOGLE_API_KEY=SECRET_PLACEHOLDER

# Brave Search (Incluido)
BRAVE_API_KEY=SECRET_PLACEHOLDER

# Perplexity (Opcional)
PERPLEXITY_API_KEY=pplx-SECRET_PLACEHOLDER

# ============================================
# NOTAS DE SEGURIDAD
# ============================================
# 1. Este archivo debe tener permisos 600
# 2. Agregar a .gitignore
# 3. Rotar tokens comprometidos inmediatamente
# 4. Usar variables de entorno cuando sea posible